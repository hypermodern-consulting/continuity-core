# examples/rust/BUCK
#
# Rust examples using hermetic Nix toolchain
#
# Uses prelude's rust_binary/rust_library with system_rust_toolchain.
# No custom .bzl needed — the prelude handles everything.

# Simple hello world binary
rust_binary(
    name = "hello-rs",
    srcs = ["hello.rs"],
    edition = "2021",
    visibility = ["PUBLIC"],
)

# Math library demonstrating rust_library
rust_library(
    name = "mathlib",
    srcs = ["mathlib.rs"],
    edition = "2021",
    visibility = ["PUBLIC"],
)

# Binary that depends on mathlib - demonstrates dependency chaining
rust_binary(
    name = "math_demo",
    srcs = ["math_demo.rs"],
    deps = [":mathlib"],
    edition = "2021",
    visibility = ["PUBLIC"],
)

# NOTE: rust_test requires test toolchain setup
# Run tests via: cargo test (in Nix devshell)
