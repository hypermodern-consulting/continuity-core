# examples/rust/BUCK
#
# Rust examples using prelude's native rust_binary/rust_library rules.
# Our rust_toolchain (in toolchains/BUCK) provides RustToolchainInfo
# that the prelude consumes. No custom rules needed for standard Rust.

rust_binary(
    name = "hello-rs",
    srcs = ["main.rs"],
    visibility = ["PUBLIC"],
)

rust_library(
    name = "mathlib",
    srcs = ["mathlib.rs"],
    visibility = ["PUBLIC"],
)

rust_binary(
    name = "math_demo",
    srcs = ["math_demo.rs"],
    deps = [":mathlib"],
    visibility = ["PUBLIC"],
)
