#!/usr/bin/env python3
"""
dhall-to-buck: Convert Dhall build rules to Buck2 BUCK files.

Usage:
  dhall-to-buck TARGETS.dhall > BUCK

The input Dhall file should evaluate to a record of { name : Rule } entries,
where Rule is the Continuity rule union type. Each entry becomes a Buck2
rule invocation in the output BUCK file.
"""

import json
import subprocess
import sys

# Map Continuity rule union tags → Buck2 rule names
RULE_MAP = {
    "CxxBinary": "cxx_binary",
    "CxxLibrary": "cxx_library",
    "RustBinary": "rust_binary",
    "RustLibrary": "rust_library",
    "HaskellBinary": "haskell_binary",
    "HaskellLibrary": "haskell_library",
    "HaskellFFIBinary": "haskell_binary",  # FFI handled via extra attrs
    "LeanBinary": "lean_binary",
    "LeanLibrary": "lean_library",
    "NvBinary": "cuda_binary",
    "NvLibrary": "cuda_library",
    "PureScriptApp": "purescript_app",
    "PureScriptBinary": "purescript_binary",
    "PureScriptLibrary": "purescript_library",
    "Genrule": "genrule",
    "NixCxxBinary": "nix_cxx_binary",
    "CratesIo": "crates_io",
    "HttpArchive": "http_archive",
}

# Map Continuity CxxStd → Buck2 string
CXX_STD_MAP = {
    "Cxx11": "c++11",
    "Cxx14": "c++14",
    "Cxx17": "c++17",
    "Cxx20": "c++20",
    "Cxx23": "c++23",
}

# Map Continuity Edition → Rust edition
EDITION_MAP = {
    "E2015": "2015",
    "E2018": "2018",
    "E2021": "2021",
    "E2024": "2024",
}

# Map Continuity Vis → Buck2 visibility
VIS_MAP = {"Public": ["PUBLIC"], "Private": []}


def render_dep(dep):
    """Convert a Continuity Dep to a Buck2 dependency string."""
    if isinstance(dep, str):
        return dep
    if isinstance(dep, dict):
        # Union value from dhall-to-json: {"Local": ":foo"} or {"Flake": "nixpkgs#bar"}
        for tag, val in dep.items():
            if tag == "Local":
                return val
            elif tag == "Flake":
                return f"//nix:{val}"  # placeholder
            elif tag == "PkgConfig":
                return f"//pkg-config:{val}"
            elif tag == "External":
                return f"//external:{val['name']}"
    return str(dep)


def render_value(val, indent=8):
    """Render a Python value as Starlark."""
    if isinstance(val, str):
        return f'"{val}"'
    elif isinstance(val, bool):
        return "True" if val else "False"
    elif isinstance(val, (int, float)):
        return str(val)
    elif isinstance(val, list):
        if not val:
            return "[]"
        items = ", ".join(render_value(v, indent) for v in val)
        if len(items) < 60:
            return f"[{items}]"
        sep = f",\n{' ' * indent}"
        return f"[\n{' ' * indent}{sep.join(render_value(v, indent) for v in val)},\n{' ' * (indent - 4)}]"
    elif val is None:
        return "None"
    return str(val)


def render_rule(tag, fields):
    """Render one Buck2 rule from a Continuity rule."""
    buck2_rule = RULE_MAP.get(tag, tag.lower())
    lines = [f"{buck2_rule}("]

    for key, val in fields.items():
        # Skip internal fields
        if key in ("type",):
            continue

        # Transform known fields
        if key == "deps":
            val = [render_dep(d) for d in val]
        elif key == "std" and isinstance(val, dict):
            for stag, _ in val.items():
                val = CXX_STD_MAP.get(stag, stag)
                break
        elif key == "edition" and isinstance(val, dict):
            for etag, _ in val.items():
                val = EDITION_MAP.get(etag, etag)
                break
        elif key == "vis" and isinstance(val, dict):
            for vtag, _ in val.items():
                val = VIS_MAP.get(vtag, [])
                key = "visibility"
                break

        lines.append(f"    {key} = {render_value(val)},")

    lines.append(")")
    return "\n".join(lines)


def main():
    if len(sys.argv) < 2:
        print("Usage: dhall-to-buck TARGETS.dhall", file=sys.stderr)
        sys.exit(1)

    dhall_file = sys.argv[1]

    # Run dhall-to-json
    try:
        result = subprocess.run(
            ["dhall-to-json"],
            input=f"./{dhall_file}",
            capture_output=True,
            text=True,
            check=True,
            cwd="." if "/" not in dhall_file else None,
        )
    except subprocess.CalledProcessError as e:
        print(f"dhall-to-json failed:\n{e.stderr}", file=sys.stderr)
        sys.exit(1)

    data = json.loads(result.stdout)

    # Output header
    print("# Generated by dhall-to-buck — do not edit")
    print()

    if isinstance(data, dict):
        for name, rule in data.items():
            if isinstance(rule, dict):
                # Detect union tag: {"CxxBinary": {fields...}}
                for tag, fields in rule.items():
                    if tag in RULE_MAP and isinstance(fields, dict):
                        print(render_rule(tag, fields))
                        print()
                        break
                    else:
                        # Plain record — try to use name as rule type hint
                        print(render_rule(name, rule))
                        print()
                        break
    elif isinstance(data, list):
        for rule in data:
            if isinstance(rule, dict):
                for tag, fields in rule.items():
                    if tag in RULE_MAP:
                        print(render_rule(tag, fields))
                        print()
                        break


if __name__ == "__main__":
    main()
