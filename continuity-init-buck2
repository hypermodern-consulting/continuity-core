#!/usr/bin/env bash
set -euo pipefail

# continuity init-buck2 --tools-specification=<path>
# Reads a tools specification and writes buck2 scaffolding.

usage() {
  echo "Usage: continuity init-buck2 --tools-specification=<path> [target-dir]"
  echo ""
  echo "Reads tool paths from a Dhall/JSON specification and generates"
  echo "the full buck2 build scaffolding: .buckconfig, toolchains/, .buckroot"
  exit 1
}

SPEC=""
TARGET="."

for arg in "$@"; do
  case "$arg" in
    --tools-specification=*) SPEC="${arg#--tools-specification=}" ;;
    --help|-h) usage ;;
    *) TARGET="$arg" ;;
  esac
done

[[ -z "$SPEC" ]] && { echo "error: --tools-specification required"; usage; }
[[ ! -f "$SPEC" ]] && { echo "error: $SPEC not found"; exit 1; }

# ── parse specification ──────────────────────────────────────────

# Parse specification: JSON directly, or Dhall via dhall-to-json
if [[ "$SPEC" == *.json ]]; then
  TOOLS=$(cat "$SPEC")
elif command -v dhall-to-json &>/dev/null; then
  TOOLS=$(dhall-to-json --file "$SPEC")
else
  # Fallback: treat as JSON-like (strip comments, hope for the best)
  TOOLS=$(grep -v '^--' "$SPEC" | sed 's/= Some //g; s/= None .*$/= null/g; s/ *,$/,/')
  echo "note: no dhall binary, using heuristic parser"
fi

# Extract tool paths with jq if available, else grep
jq_get() {
  local path="$1"
  # Inline micro-JSON extractor (no jq dependency)
  python3 -c "
import json, sys
try:
  d = json.loads(sys.stdin.read())
  keys = '${path}'.replace('.','|').strip('|').split('|')
  v = d
  for k in keys:
    if v is None: break
    v = v.get(k) if isinstance(v, dict) else None
  print(v if v is not None else 'null')
except: print('null')
" <<< "$TOOLS"
}

LEAN_ROOT=$(jq_get 'lean.root')
CC=$(jq_get 'cxx.cc')
CXX=$(jq_get 'cxx.cxx')
GHC=$(jq_get 'haskell.ghc')
CABAL=$(jq_get 'haskell.cabal')
RUSTC=$(jq_get 'rust.rustc')
CARGO=$(jq_get 'rust.cargo')
NVCC=$(jq_get 'nv.nvcc')
REAPI_ENDPOINT=$(jq_get 'reapi.endpoint')
REAPI_INSTANCE=$(jq_get 'reapi.instance_name')

echo "continuity init-buck2"
echo "  spec: $SPEC"
echo "  target: $TARGET"

# ── generate scaffolding ─────────────────────────────────────────

mkdir -p "$TARGET/toolchains"

# .buckroot
touch "$TARGET/.buckroot"

# .buckconfig
cat > "$TARGET/.buckconfig" << BUCKCONFIG
[cells]
  root = .
  prelude = prelude
  toolchains = toolchains
  none = none
[cell_aliases]
  config = prelude
  ovr_config = prelude
  fbcode = none
  fbsource = none
  fbcode_macros = none
  buck = none
[external_cells]
  prelude = bundled
[parser]
  target_platform_detector_spec = target:root//...->prelude//platforms:default
[build]
  execution_platforms = prelude//platforms:default
BUCKCONFIG

# Lean toolchain
if [[ "$LEAN_ROOT" != "null" ]]; then
  cat >> "$TARGET/.buckconfig" << LEAN
[lean]
  lean = ${LEAN_ROOT}/bin/lean
  leanc = ${LEAN_ROOT}/bin/leanc
  lean_lib_dir = ${LEAN_ROOT}/lib/lean
  lean_include_dir = ${LEAN_ROOT}/include
LEAN
  echo "  ✓ lean: $LEAN_ROOT"
fi

# C++ toolchain
if [[ "$CC" != "null" ]]; then
  cat >> "$TARGET/.buckconfig" << CXX_CFG
[cxx]
  cc = ${CC}
  cxx = ${CXX}
CXX_CFG
  echo "  ✓ cxx: $CC"
fi

# Haskell toolchain
if [[ "$GHC" != "null" ]]; then
  cat >> "$TARGET/.buckconfig" << HS_CFG
[haskell]
  ghc = ${GHC}
  cabal = ${CABAL}
HS_CFG
  echo "  ✓ haskell: $GHC"
fi

# REAPI remote execution
if [[ "$REAPI_ENDPOINT" != "null" ]]; then
  cat >> "$TARGET/.buckconfig" << REAPI_CFG
[reapi]
  endpoint = ${REAPI_ENDPOINT}
  instance_name = ${REAPI_INSTANCE}
REAPI_CFG
  echo "  ✓ reapi: $REAPI_ENDPOINT"
fi

# ── lean.bzl ─────────────────────────────────────────────────────

if [[ "$LEAN_ROOT" != "null" ]]; then
  # Copy lean.bzl from continuity's own toolchains
  SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  if [[ -f "$SCRIPT_DIR/toolchains/lean.bzl" ]]; then
    cp "$SCRIPT_DIR/toolchains/lean.bzl" "$TARGET/toolchains/lean.bzl"
  else
    echo "  warning: lean.bzl not found at $SCRIPT_DIR/toolchains/"
  fi
fi

# ── toolchains/BUCK ──────────────────────────────────────────────

cat > "$TARGET/toolchains/BUCK" << 'TBUCK'
load("@prelude//toolchains:demo.bzl", "system_demo_toolchains")
system_demo_toolchains()
TBUCK

# ── .gitignore additions ─────────────────────────────────────────

for entry in buck-out .buckroot; do
  grep -qxF "$entry" "$TARGET/.gitignore" 2>/dev/null || echo "$entry" >> "$TARGET/.gitignore"
done

echo ""
echo "Done. Run: cd $TARGET && buck2 build //..."
