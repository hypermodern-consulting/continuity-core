---                                                           // archive // nar
--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def NAR_MAGIC : String := "nix-archive-1"

inductive NarEntry where
  | regular (executable : Bool) (contents : Bytes)
  | directory (entries : List (String × NarEntry))
  | symlink (target : String)

inductive HashAlgorithm where | sha256 | sha512 | sha1 | md5 deriving Repr, DecidableEq
inductive ContentAddressMethod where | flat | nar | text | git deriving Repr, DecidableEq

end Continuity.Codec.Protocol.Nix
