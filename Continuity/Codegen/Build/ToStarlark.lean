/-!
  Starlark codegen for Buck2 toolchains.

  This module defines the toolchains/BUCK file and custom .bzl files
  as typed values, then renders them to Starlark text via the renderer.

  The BUCK file uses the prelude's system toolchains for C++, Haskell,
  and Rust. Custom .bzl files are only needed for languages the prelude
  doesn't support: Lean, NV (CUDA), and PureScript.

  Toolchain paths (cc, ghc, lean, etc.) are read from .buckconfig at
  runtime via read_root_config(). The .buckconfig.local file is generated
  by the Nix flake module with Nix store paths.
-/

set_option autoImplicit false

namespace Continuity.Codegen.Build.Starlark

open Continuity.Build
open Continuity.Emit.Starlark


/- ════════════════════════════════════════════════════════════════════════════════
                                              // toolchains/BUCK generation
   ════════════════════════════════════════════════════════════════════════════════ -/

/-- Configuration for which toolchains to enable in the BUCK file. -/
structure ToolchainConfig where
  cxx        : Bool := false
  haskell    : Bool := false
  rust       : Bool := false
  lean       : Bool := false
  nv         : Bool := false
  purescript : Bool := false
  python     : Bool := false
  deriving Repr, Inhabited

/-- Generate the toolchains/BUCK file contents. -/
def mkToolchainsBuck (config : ToolchainConfig) : BuckFile :=
  let header := "# toolchains/BUCK — generated by continuity\n#\n# Tool paths read from .buckconfig.local (generated by Nix)."

  -- Collect loads
  let loads : List Load := List.filter (fun l => !l.symbols.isEmpty) [
    -- System toolchains from prelude
    ⟨"@prelude//toolchains:genrule.bzl", ["system_genrule_toolchain"]⟩,
    ⟨"@prelude//toolchains:python.bzl", ["system_python_bootstrap_toolchain"]⟩,
    -- CXX from prelude (handles CxxToolchainInfo compatibility)
    (if config.cxx then
      ⟨"@prelude//toolchains:cxx.bzl", ["system_cxx_toolchain"]⟩
    else ⟨"", []⟩),
    -- Custom toolchains
    (if config.lean then ⟨":lean.bzl", ["lean_toolchain"]⟩ else ⟨"", []⟩),
    (if config.haskell then ⟨":haskell.bzl", ["haskell_toolchain"]⟩ else ⟨"", []⟩),
    (if config.rust then ⟨":rust.bzl", ["rust_toolchain"]⟩ else ⟨"", []⟩),
    (if config.nv then ⟨":nv.bzl", ["nv_toolchain"]⟩ else ⟨"", []⟩),
    (if config.purescript then ⟨":purescript.bzl", ["purescript_toolchain"]⟩ else ⟨"", []⟩)
  ]

  -- Collect toolchain calls
  let pub : List String := ["PUBLIC"]
  let calls : List ToolchainCall := List.filter (fun t => !t.name.isEmpty) [
    -- System toolchains
    ⟨"system_python_bootstrap_toolchain", "python_bootstrap", [], pub⟩,
    ⟨"system_genrule_toolchain", "genrule", [], pub⟩,
    -- CXX via prelude (always compatible with current prelude version)
    (if config.cxx then
      ⟨"system_cxx_toolchain", "cxx",
        [("compiler_type", "\"clang\""),
         ("cxx_flags", "[\"-std=c++23\", \"-Wall\", \"-Wextra\", \"-fno-exceptions\"]"),
         ("c_flags", "[\"-std=c23\", \"-Wall\", \"-Wextra\"]"),
         ("link_style", "\"static\"")], pub⟩
    else ⟨"", "", [], pub⟩),
    -- Lean
    (if config.lean then
      ⟨"lean_toolchain", "lean", [], pub⟩
    else ⟨"", "", [], pub⟩),
    -- Haskell
    (if config.haskell then
      ⟨"haskell_toolchain", "haskell",
        [("compiler_flags", "[\"-Wall\", \"-XGHC2024\"]")], pub⟩
    else ⟨"", "", [], pub⟩),
    -- Rust
    (if config.rust then
      ⟨"rust_toolchain", "rust",
        [("default_edition", "\"2021\"")], pub⟩
    else ⟨"", "", [], pub⟩),
    -- NV
    (if config.nv then
      ⟨"nv_toolchain", "nv",
        [("nv_archs", "[\"sm_90\", \"sm_100\", \"sm_120\"]")], pub⟩
    else ⟨"", "", [], pub⟩),
    -- PureScript
    (if config.purescript then
      ⟨"purescript_toolchain", "purescript", [], pub⟩
    else ⟨"", "", [], pub⟩)
  ]

  { header, loads, calls }


/- ════════════════════════════════════════════════════════════════════════════════
                                                                    // tests
   ════════════════════════════════════════════════════════════════════════════════ -/

-- Generate BUCK for all toolchains
def allToolchains : ToolchainConfig :=
  { cxx := true, haskell := true, rust := true, lean := true,
    nv := true, purescript := true, python := true }

-- Generate BUCK for a minimal project (cxx + lean)
def minToolchains : ToolchainConfig :=
  { cxx := true, lean := true }

#eval renderBuckFile (mkToolchainsBuck allToolchains)
#eval renderBuckFile (mkToolchainsBuck minToolchains)


/- ════════════════════════════════════════════════════════════════════════════════
                                                // starlark file list
   ════════════════════════════════════════════════════════════════════════════════ -/

/-- All generated Starlark files for a given toolchain configuration.
    Returns (path, content) pairs. -/
def starlarkFiles (config : ToolchainConfig) : List (String × String) :=
  [("toolchains/BUCK", renderBuckFile (mkToolchainsBuck config))]
  -- TODO: add generated lean.bzl, nv.bzl, purescript.bzl
  -- once their BzlFile definitions are written


end Continuity.Codegen.Build.Starlark
