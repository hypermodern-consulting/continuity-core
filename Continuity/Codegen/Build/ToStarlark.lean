namespace Continuity.Codegen.Build.Starlark

/-
  Starlark codegen for Buck2 toolchains.

  All toolchains are ours: `llvm_toolchain`, `haskell_toolchain`,
  `rust_toolchain`, `lean_toolchain`, `nv_toolchain`, `purescript_toolchain`.
  Each is defined in its own `.bzl` file under `toolchains/`.

  The single bootstrap requirement is `system_python_bootstrap_toolchain`
  and `system_genrule_toolchain` from the prelude. Nothing else comes
  from outside.

  Tool paths (cc, ghc, lean, rustc, etc.) are read from `.buckconfig`
  at runtime via `read_root_config()`. The `.buckconfig.local` file is
  generated by the Nix flake module with Nix store paths.
-/

--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
---                                                // toolchains // generation
--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

structure ToolchainConfig where
  cxx        : Bool := false
  haskell    : Bool := false
  rust       : Bool := false
  lean       : Bool := false
  nv         : Bool := false
  purescript : Bool := false
  deriving Repr, Inhabited

private def escapeStr (s : String) : String :=
  s.foldl (fun acc c =>
    match c with
    | '\\' => acc ++ "\\\\"
    | '"'  => acc ++ "\\\""
    | '\n' => acc ++ "\\n"
    | '\t' => acc ++ "\\t"
    | c    => acc.push c
  ) ""

private def strLit (s : String) : String := s!"\"{escapeStr s}\""

private def renderLoad (path : String) (symbols : List String) : String :=
  let syms := String.intercalate ", " (symbols.map strLit)
  s!"load({strLit path}, {syms})"

private def renderToolchainCall (funcName : String) (name : String)
    (kwargs : List (String × String)) (visibility : List String) : String :=
  let kwargLines := kwargs.map fun (k, v) => s!"    {k} = {v},"
  let vis := if visibility.isEmpty then "[]"
    else s!"[{String.intercalate ", " (visibility.map strLit)}]"
  let allLines := [s!"    name = {strLit name},"]
    ++ kwargLines
    ++ [s!"    visibility = {vis},"]
  s!"{funcName}(\n{String.intercalate "\n" allLines}\n)"

def mkToolchainsBuck (config : ToolchainConfig) : String :=
  let header := String.intercalate "\n"
    [ "# toolchains/BUCK — generated by continuity"
    , "#"
    , "# All toolchains are ours. Tool paths read from"
    , "# .buckconfig.local (generated by Nix)."
    , "#"
    , "# Bootstrap only: system_python_bootstrap_toolchain,"
    , "#                 system_genrule_toolchain" ]

  let pub : List String := ["PUBLIC"]

  let loads : List String := List.filter (· ≠ "") [
    (if config.cxx        then renderLoad ":cxx.bzl" ["llvm_toolchain"] else ""),
    (if config.haskell    then renderLoad ":haskell.bzl" ["haskell_toolchain"] else ""),
    (if config.rust       then renderLoad ":rust.bzl" ["rust_toolchain"] else ""),
    (if config.lean       then renderLoad ":lean.bzl" ["lean_toolchain"] else ""),
    (if config.nv         then renderLoad ":nv.bzl" ["nv_toolchain"] else ""),
    (if config.purescript then renderLoad ":purescript.bzl" ["purescript_toolchain"] else ""),
    renderLoad "@prelude//toolchains:python.bzl" ["system_python_bootstrap_toolchain"],
    renderLoad "@prelude//toolchains:genrule.bzl" ["system_genrule_toolchain"]
  ]

  let calls : List String := List.filter (· ≠ "") [
    (if config.cxx then
      renderToolchainCall "llvm_toolchain" "cxx"
        [ ("c_extra_flags", "[\"-std=c23\", \"-Wall\", \"-Wextra\"]")
        , ("cxx_extra_flags", "[\"-std=c++23\", \"-Wall\", \"-Wextra\", \"-fno-exceptions\"]")
        , ("link_flags", "[]")
        , ("link_style", "\"static\"") ] pub
    else ""),

    (if config.haskell then
      renderToolchainCall "haskell_toolchain" "haskell"
        [ ("compiler_flags", "[\"-Wall\", \"-Werror\", \"-XGHC2024\"]") ] pub
    else ""),

    (if config.rust then
      renderToolchainCall "rust_toolchain" "rust"
        [ ("default_edition", "\"2021\"")
        , ("rustc_flags", "[\"-C\", \"opt-level=2\"]") ] pub
    else ""),

    (if config.lean then
      renderToolchainCall "lean_toolchain" "lean" [] pub
    else ""),

    (if config.nv then
      renderToolchainCall "nv_toolchain" "nv"
        [ ("nv_archs", "[\"sm_90\", \"sm_100\", \"sm_120\"]") ] pub
    else ""),

    (if config.purescript then
      renderToolchainCall "purescript_toolchain" "purescript" [] pub
    else ""),

    renderToolchainCall "system_python_bootstrap_toolchain" "python_bootstrap" [] pub,
    renderToolchainCall "system_genrule_toolchain" "genrule" [] pub
  ]

  let sections : List String := List.filter (· ≠ "") (
    [header] ++ loads ++ calls)
  String.intercalate "\n\n" sections ++ "\n"

--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
---                                                                    // tests
--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def allToolchains : ToolchainConfig :=
  { cxx := true, haskell := true, rust := true, lean := true,
    nv := true, purescript := true }

def minToolchains : ToolchainConfig :=
  { cxx := true, lean := true }

