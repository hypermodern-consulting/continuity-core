     ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━ -/

namespace Continuity.Codegen.Build.Starlark

/-
  Starlark codegen for Buck2 toolchains.

  All toolchains are ours: `llvm_toolchain`, `haskell_toolchain`,
  `rust_toolchain`, `lean_toolchain`, `nv_toolchain`, `purescript_toolchain`.
  Each is defined in its own `.bzl` file under `toolchains/`.

  The single bootstrap requirement is `system_python_bootstrap_toolchain`
  and `system_genrule_toolchain` from the prelude. Nothing else comes
  from outside.

  Tool paths (cc, ghc, lean, rustc, etc.) are read from `.buckconfig`
  at runtime via `read_root_config()`. The `.buckconfig.local` file is
  generated by the Nix flake module with Nix store paths.
-/

open Continuity.Codegen.AST.Starlark

--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
---                                                // toolchains // generation
--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

structure ToolchainConfig where
  cxx        : Bool := false
  haskell    : Bool := false
  rust       : Bool := false
  lean       : Bool := false
  nv         : Bool := false
  purescript : Bool := false
  deriving Repr, Inhabited

def mkToolchainsBuck (config : ToolchainConfig) : BuckFile :=
  let header := String.intercalate "\n"
    [ "# toolchains/BUCK — generated by continuity"
    , "#"
    , "# All toolchains are ours. Tool paths read from"
    , "# .buckconfig.local (generated by Nix)."
    , "#"
    , "# Bootstrap only: system_python_bootstrap_toolchain,"
    , "#                 system_genrule_toolchain" ]

  let pub : List String := ["PUBLIC"]
  let empty : Load := ⟨"", []⟩
  let skip : ToolchainCall := ⟨"", "", [], pub⟩

  -- our toolchains — everything loads from our `.bzl` files
  let loads : List Load := List.filter (fun l => !l.symbols.isEmpty) [
    (if config.cxx        then ⟨":cxx.bzl", ["llvm_toolchain"]⟩ else empty),
    (if config.haskell    then ⟨":haskell.bzl", ["haskell_toolchain"]⟩ else empty),
    (if config.rust       then ⟨":rust.bzl", ["rust_toolchain"]⟩ else empty),
    (if config.lean       then ⟨":lean.bzl", ["lean_toolchain"]⟩ else empty),
    (if config.nv         then ⟨":nv.bzl", ["nv_toolchain"]⟩ else empty),
    (if config.purescript then ⟨":purescript.bzl", ["purescript_toolchain"]⟩ else empty),

    -- bootstrap — the only things from outside
    ⟨"@prelude//toolchains:python.bzl", ["system_python_bootstrap_toolchain"]⟩,
    ⟨"@prelude//toolchains:genrule.bzl", ["system_genrule_toolchain"]⟩
  ]

  -- TODO[b7r6]: !! hoist these up as functions or terms !!

  -- toolchain registrations
  let calls : List ToolchainCall := List.filter (fun t => !t.name.isEmpty) [

    (if config.cxx then
      ⟨"llvm_toolchain", "cxx",
        [ ("c_extra_flags", "[\"-std=c23\", \"-Wall\", \"-Wextra\"]")
        , ("cxx_extra_flags", "[\"-std=c++23\", \"-Wall\", \"-Wextra\", \"-fno-exceptions\"]")
        , ("link_flags", "[]")
        , ("link_style", "\"static\"") ], pub⟩

    else skip),

    (if config.haskell then
      ⟨"haskell_toolchain", "haskell",
        [ ("compiler_flags", "[\"-Wall\", \"-Werror\", \"-XGHC2024\"]") ], pub⟩

    else skip),

    (if config.rust then
      ⟨"rust_toolchain", "rust",
        [ ("default_edition", "\"2021\"")
        , ("rustc_flags", "[\"-C\", \"opt-level=2\"]") ], pub⟩

    else skip),

    (if config.lean then
      ⟨"lean_toolchain", "lean", [], pub⟩
    else skip),

    (if config.nv then
      ⟨"nv_toolchain", "nv",
        [ ("nv_archs", "[\"sm_90\", \"sm_100\", \"sm_120\"]") ], pub⟩
    else skip),

    (if config.purescript then
      ⟨"purescript_toolchain", "purescript", [], pub⟩
    else skip),

    ⟨"system_python_bootstrap_toolchain", "python_bootstrap", [], pub⟩,
    ⟨"system_genrule_toolchain", "genrule", [], pub⟩
  ]

  { header, loads, calls }

--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
---                                                                    // tests
--- ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def allToolchains : ToolchainConfig :=
  { cxx := true, haskell := true, rust := true, lean := true,
    nv := true, purescript := true }

def minToolchains : ToolchainConfig :=
  { cxx := true, lean := true }

