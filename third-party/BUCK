# third-party/BUCK — C++ libraries resolved by Nix
#
# Paths come from .buckconfig.local [lib.*] sections.

prebuilt_cxx_library(
    name = "curl",
    header_dirs = [read_root_config("lib.curl", "include", "")],
    exported_linker_flags = [
        "-L" + read_root_config("lib.curl", "lib", ""),
        "-lcurl",
    ],
    visibility = ["PUBLIC"],
)

