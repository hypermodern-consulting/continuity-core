# third-party/BUCK — C++ libraries resolved by Nix
#
# Absolute Nix store paths go through -isystem flags, not header_dirs
# (Buck2 header_dirs requires relative source paths).

prebuilt_cxx_library(
    name = "curl",
    exported_preprocessor_flags = [
        "-isystem", read_root_config("lib.curl", "include", ""),
    ],
    exported_linker_flags = [
        "-L" + read_root_config("lib.curl", "lib", ""),
        "-lcurl",
    ],
    visibility = ["PUBLIC"],
)

prebuilt_cxx_library(
    name = "zlib",
    exported_preprocessor_flags = [
        "-isystem", read_root_config("lib.zlib", "include", ""),
    ],
    exported_linker_flags = [
        "-L" + read_root_config("lib.zlib", "lib", ""),
        "-lz",
    ],
    visibility = ["PUBLIC"],
)

prebuilt_cxx_library(
    name = "openssl",
    exported_preprocessor_flags = [
        "-isystem", read_root_config("lib.openssl", "include", ""),
    ],
    exported_linker_flags = [
        "-L" + read_root_config("lib.openssl", "lib", ""),
        "-lssl",
        "-lcrypto",
    ],
    visibility = ["PUBLIC"],
)

prebuilt_cxx_library(
    name = "simdjson",
    exported_preprocessor_flags = [
        "-isystem", read_root_config("lib.simdjson", "include", ""),
    ],
    exported_linker_flags = [
        "-L" + read_root_config("lib.simdjson", "lib", ""),
        "-lsimdjson",
    ],
    visibility = ["PUBLIC"],
)
